{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch:esbuild",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": [
          {
            "regexp": "\\[ERROR\\] (.+)",
            "file": 1,
            "location": 2,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      }
    }
  ]
}
