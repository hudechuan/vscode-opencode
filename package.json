{
  "name": "opencode-agent",
  "displayName": "OpenCode Agent",
  "description": "OpenCode Agent for VSCode",
  "version": "0.0.4",
  "publisher": "wenzewoo",
  "repository": {
    "type": "git",
    "url": "https://github.com/wenzewoo/vscode-opencode"
  },
  "license": "MIT",
  "icon": "resources/logo.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "activationEvents": [],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "opencode-agent.start",
        "title": "%opencode-agent.start.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.create",
        "title": "%opencode-agent.create.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.append-file",
        "title": "%opencode-agent.append-file.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.append-selection",
        "title": "%opencode-agent.append-selection.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.review-selection",
        "title": "%opencode-agent.review-selection.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.attach",
        "title": "%opencode-agent.attach.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.continue",
        "title": "%opencode-agent.continue.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opencode-agent.start",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-agent.append-file",
          "group": "opencode"
        },
        {
          "command": "opencode-agent.append-selection",
          "when": "editorHasSelection",
          "group": "opencode"
        },
        {
          "command": "opencode-agent.review-selection",
          "when": "editorHasSelection",
          "group": "opencode"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode-agent.append-file",
          "group": "opencode"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode Agent",
      "properties": {
        "opencode-agent.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the opencode CLI executable"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}