{
  "name": "opencode-agent",
  "displayName": "OpenCode Agent",
  "description": "OpenCode Agent for VSCode",
  "version": "0.0.2",
  "publisher": "wenzewoo",
  "repository": {
    "type": "git",
    "url": "https://github.com/wenzewoo/vscode-opencode"
  },
  "license": "MIT",
  "icon": "resources/logo.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "activationEvents": [],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "opencode-agent.create",
        "title": "%opencode-agent.create.title%",
        "icon": {
          "light": "resources/logo-light.svg",
          "dark": "resources/logo-dark.svg"
        }
      },
      {
        "command": "opencode-agent.append-path",
        "title": "%opencode-agent.append-path.title%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opencode-agent.create",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "submenu": "opencode-agent.submenu",
          "group": "7_opencode"
        }
      ],
      "explorer/context": [
        {
          "submenu": "opencode-agent.submenu",
          "group": "7_opencode"
        }
      ],
      "opencode-agent.submenu": [
        {
          "command": "opencode-agent.create"
        },
        {
          "command": "opencode-agent.append-path"
        }
      ]
    },
    "submenus": [
      {
        "id": "opencode-agent.submenu",
        "label": "%opencode-agent.submenu.label%"
      }
    ],
    "configuration": {
      "title": "OpenCode Terminal",
      "properties": {
        "opencode-agent.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the opencode CLI executable"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}